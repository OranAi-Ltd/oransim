# ============================================================================
# Oransim — environment variable template
# Copy to `.env` and fill in values for real-LLM mode.
# All keys are read by `oransim.agents.soul_llm` + `oransim.runtime.real_embedder`.
# ============================================================================

# --- LLM provider ------------------------------------------------------------
# "mock" returns deterministic stub responses (no network, free). Use for CI +
# local exploration. "api" requires a real key below.
LLM_MODE=mock

# Which native request format to speak. Defaults to OpenAI chat/completions.
#   openai     — OpenAI / DeepSeek / OpenRouter / vLLM / any OpenAI-compat
#   anthropic  — Anthropic /v1/messages (system as top-level field)
#   gemini     — Google generateContent (systemInstruction + contents/parts)
#   qwen       — Alibaba Qwen DashScope native /generation endpoint
# Aliases accepted: openai_compat, claude, google, dashscope.
LLM_PROVIDER=openai

# Shared base URL + API key. Used by the active provider unless you override
# with the provider-specific vars below.
#
# OpenAI-compat endpoints (LLM_PROVIDER=openai):
#   OpenAI:        https://api.openai.com/v1
#   DeepSeek:      https://api.deepseek.com/v1
#   Qwen compat:   https://dashscope.aliyuncs.com/compatible-mode/v1
#   Moonshot/Kimi: https://api.moonshot.cn/v1
#   xAI:           https://api.x.ai/v1
#   Together AI:   https://api.together.xyz/v1
#   Fireworks AI:  https://api.fireworks.ai/inference/v1
#   Local vLLM:    http://localhost:8000/v1
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-5.4

# Provider-specific overrides (optional — fall back to LLM_BASE_URL / LLM_API_KEY):
#   ANTHROPIC_API_KEY=sk-ant-...
#   ANTHROPIC_BASE_URL=https://api.anthropic.com
#   ANTHROPIC_VERSION=2023-06-01
#   GEMINI_API_KEY=AIza...
#   GEMINI_BASE_URL=https://generativelanguage.googleapis.com
#   DASHSCOPE_API_KEY=sk-...
#   DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# Timeout seconds per call.
LLM_TIMEOUT=15

# --- Soul-agent scaling ------------------------------------------------------
# Number of LLM personas for the soul-agent layer. 100 is a sensible default;
# production deployments scale to 10k via a Ray cluster (roadmap v0.5).
SOUL_POOL_N=100

# --- Base population ---------------------------------------------------------
# 1M agents for full-fidelity; reduce for dev (minimum 10_000 for api.py
# bootstrap — below that the UEB sample indexing fails).
POP_SIZE=100000

# --- Backend server ----------------------------------------------------------
PORT=8001

# --- Optional: embedder endpoint ---------------------------------------------
# If unset, defaults to the LLM_BASE_URL above. Many providers require a
# separate embeddings endpoint or model — override here if needed.
# EMB_BASE_URL=https://api.openai.com/v1
# EMB_MODEL=text-embedding-3-small
